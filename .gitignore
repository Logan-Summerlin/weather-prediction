# Raw data files (large, re-downloadable)
data/raw/*.dly
data/raw/*.csv
data/raw/kalshi_api/
# Raw ASOS hourly archives per city (large, re-downloadable from IEM).
# Processed ASOS daily aggregates and feature splits ARE tracked.
data/*/raw/asos/
# Transient GHCN feature backups created during ASOS migration (parity
# baselines; the GHCN feature splits remain available via git history).
data/*/processed/features_*_ghcn_backup.csv
# NYC reorganization: NYC raw GHCN station files + processed feature splits
# are large and regenerated by the pipeline; keep the dir placeholders only.
data/nyc/raw/*.dly
data/nyc/raw/*.csv
data/nyc/processed/*
!data/nyc/raw/.gitkeep
!data/nyc/processed/.gitkeep
data/processed/
data/processed_v2/
data/processed_expanded/
data/ghcnd-stations.txt
data/ghcnd-inventory.txt
data/station_completeness.csv
data/replacement_stations.txt

# Model checkpoints (large)
models/

# OS
.DS_Store
Thumbs.db
# Generated model artifacts (binary; do not commit in PRs)
results/phase1_combined/*.pt
results/phase1_combined/*.pkl

# Phase 3 runtime outputs (per-day signals + paper-trade audit logs).
# The promoted strategy (results/<city>/strategy.json) and the sweep audit
# tables ARE durable and committed; per-day run artifacts are not.
results/*/live/
results/live/
results/*/trading/trading_audit_*.json
results/trading/trading_audit_*.json

